{% extends 'base.html.twig' %}

{% block title %}Liste des vacataires
{% endblock %}

{% block body %}
	<div class="container mt-4">
		<h1>Liste des vacataires</h1>
		<table class="table table-hover mt-4">
			<thead>
				<tr>
					<th scope="col">ID</th>
					<th scope="col">Nom</th>
				</tr>
			</thead>
			<tbody>
				{% for vacataire in vacataires %}
					<tr class="table-active">
						<th scope="row">{{ vacataire.id }}</th>
						<td>{{ vacataire.nom }}</td>
					</tr>
				{% endfor %}
			</tbody>
		</table>

		{# Affichage des liens de navigation de la pagination #}
		<div class="navigation d-flex justify-content-center">
			{{ knp_pagination_render(vacataires) }}
		</div>
	</div>
{% endblock %}
